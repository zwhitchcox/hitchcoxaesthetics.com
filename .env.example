GA_CONVERSION_LABEL="FSkICMDPwMgZEM3Mi98D"


# the mocks and some code rely on these two being prefixed with "MOCK_"
# if they aren't then the real github api will be attempted
GITHUB_CLIENT_ID="MOCK_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="MOCK_GITHUB_CLIENT_SECRET"
GITHUB_TOKEN="MOCK_GITHUB_TOKEN"

# set this to false to prevent search engines from indexing the website
# default to allow indexing for seo safety
ALLOW_INDEXING="true"

TWILIO_PHONE_NUMBER='+18655555555'
TWILIO_ACCOUNT_SID='not-a-real-sid'
TWILIO_AUTH_TOKEN='not-a-real-token'

DEFAULT_PROVIDER=sarah
GOOGLE_MAPS_API_KEY="AIza..."
CALLRAIL_API_KEY="callrail-api-key"
CALLRAIL_ACCOUNT_ID="ACC..."
# Production background job interval for syncing qualified CallRail calls into PostHog.
CALLRAIL_POSTHOG_SYNC_INTERVAL_MINUTES="30"
# Set to 1 only if you intentionally want background jobs to auto-run locally.
ENABLE_DEV_BACKGROUND_JOBS="0"

BLVD_API_KEY="00000000-0000-0000-0000-000000000000"
BLVD_BUSINESS_ID="00000000-0000-0000-0000-000000000000"
BLVD_SECRET_KEY="base64-secret-key"
BLVD_CLIENT_URL_TEMPLATE="https://dashboard.boulevard.io/clients/{id}"
