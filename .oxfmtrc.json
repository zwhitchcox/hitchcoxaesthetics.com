{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "avoid",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"embeddedLanguageFormatting": "auto",
	"endOfLine": "lf",
	"htmlWhitespaceSensitivity": "css",
	"insertPragma": false,
	"jsxSingleQuote": false,
	"printWidth": 80,
	"proseWrap": "always",
	"quoteProps": "as-needed",
	"requirePragma": false,
	"semi": false,
	"singleAttributePerLine": false,
	"singleQuote": true,
	"tabWidth": 2,
	"trailingComma": "all",
	"useTabs": true,
	"sortTailwindcss": {},
	"sortPackageJson": false,
	"ignorePatterns": [
		"node_modules",
		"/build",
		"/public/build",
		"/server-build",
		".env",
		"/test-results/",
		"/playwright-report/",
		"/playwright/.cache/",
		"/tests/fixtures/email/*.json",
		"/coverage",
		"/prisma/migrations",
		"package-lock.json"
	]
}
